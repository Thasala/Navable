# Backend configuration for Navable
#
# Copy this file to ".env" and fill in the values.

# Required: OpenAI API key used by the backend only.
# Used for assistant answers, summaries, transcription, translation, and AI site URL resolution.
# Never expose this key to the browser extension or commit your real key.
OPENAI_API_KEY=sk-...


# Optional: model name to use for summarization.
# If omitted, a sensible default like "gpt-4.1-mini" will be used.
# OPENAI_MODEL=gpt-4.1-mini

# Optional: model name to use for voice transcription.
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional: port for the backend HTTP server.
# The extension assumes http://localhost:3000 by default.
# PORT=3000

# Optional: comma-separated allowed browser origins.
# Use this before Chrome Store publishing, when you know the extension ID.
# CORS_ORIGINS=chrome-extension://your-extension-id

# Optional: allow all CORS origins for local/private demos.
# Do not leave this enabled for a public production release.
# CORS_ALLOW_ALL=true

# Optional: request limits for /api routes.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=60

# Optional: disable runtime settings mutation in production.
# NAVABLE_SETTINGS_WRITABLE=false
